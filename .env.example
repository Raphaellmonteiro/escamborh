# ── Banco de dados (Supabase) ─────────────────────────────────────────────────
# URI direta (porta 5432, host db.*): boa para um único backend Node com poucas conexões.
# Pooler "Session mode" (host pooler.*, porta 5432): cada cliente do pg = 1 slot do pool_size
#   do projeto; se o app abrir mais conexões que esse limite → MaxClientsInSessionMode.
# Pooler "Transaction mode" (porta 6543): aguenta mais clientes, mas tem restrições (ex.: sem
#   prepared statements por sessão). Para este monólito, prefira URI direta ou Session com PG_POOL_MAX baixo.
# Project Settings → Database → Connection string → URI
# Troque [YOUR-PASSWORD] pela senha que você definiu ao criar o projeto
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Opcional: conexão só para migrações (recomendado se DATABASE_URL usa pooler Session e estoura MaxClientsInSessionMode no boot).
# Use a URI direta ao Postgres (host db.*, porta 5432) — a mesma do exemplo acima costuma servir.
# DATABASE_MIGRATION_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Desliga migração automática no boot (`npm run dev` / server). Com false, rode `npm run migrate` manualmente.
# RUN_MIGRATIONS_ON_BOOT=false

# Máximo de conexões do node-pg (deve ser ≤ pool_size do Supabase em Session mode; Free/Nano costuma ser baixo)
# PG_POOL_MAX=6

# Produção (Railway, Neon, etc.): TLS do Postgres usa rejectUnauthorized=false por padrão para evitar
# SELF_SIGNED_CERT_IN_CHAIN. Para verificação estrita, defina a CA do provedor:
# DB_SSL_CA=/caminho/para/ca.pem   (ou cole o PEM completo na variável)

# ── Segredos de autenticação ──────────────────────────────────────────────────
# Gere valores aleatórios e fortes em produção:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=MUDE_PARA_UM_VALOR_SECRETO_E_LONGO
ADMIN_SECRET=MUDE_PARA_OUTRO_VALOR_SECRETO_E_LONGO

# CPF de funcionários (RH) em repouso: AES-256-GCM. Sem esta variável, o CPF continua em texto
# legível no banco (apenas dígitos). Em produção, use 64 caracteres hex (32 bytes), por exemplo:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# FUNCIONARIO_CPF_ENCRYPTION_KEY=

# ── Painel administrativo ─────────────────────────────────────────────────────
ADMIN_USER=admin@seudominio.com
ADMIN_PASSWORD=senha-admin-segura

# ── Configurações do servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# SSE (diagnostico / mitigacao leve)
# O limite por tenant vale apenas dentro de uma unica instancia Node.
# Em multi-instancia, cada replica mantem seu proprio contador e seus proprios clientes SSE.
# SSE_MAX_PER_TENANT=48
# Identificador opcional da replica para aparecer em logs e headers de diagnostico.
# SSE_INSTANCE_ID=flowpdv-web-1
# Quando 1, registra abertura/fechamento de streams SSE com tenant e contagem local.
# SSE_LOG_CONNECTIONS=0

# Uploads persistentes (Railway volume, VPS, etc.): caminho absoluto no disco.
# Ex.: monte um volume em /data e use FLOWPDV_UPLOADS_DIR=/data/uploads
# FLOWPDV_UPLOADS_DIR=/data/uploads

# Storage S3-compatível (AWS S3, Cloudflare R2, MinIO): após upload o arquivo vai ao bucket
# e o banco guarda URL absoluta. Opcional; sem isso os arquivos ficam só em UPLOADS_ROOT.
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_PUBLIC_BASE_URL=https://pub-xxx.r2.dev
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# MinIO / path-style: S3_FORCE_PATH_STYLE=true

# Cloudinary — OBRIGATÓRIO em produção (o servidor não sobe sem isso, exceto escape abaixo).
# Imagens: produtos, logo do estabelecimento, logo/banners do cardápio online, fotos RH.
# Em desenvolvimento, sem Cloudinary, uploads ficam em /uploads (apenas local).
#
# Escape hatch (somente com volume persistente em UPLOADS_ROOT): permitir /uploads em produção
# FLOWPDV_ALLOW_LOCAL_UPLOADS=true
# Dashboard → Account API → variável no formato:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Ou defina as três variáveis abaixo (sem CLOUDINARY_URL):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── CORS (adicione a URL do seu frontend em produção) ─────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ── FlowAI (opcional — análise com Claude no backend) ──────────────────────────
# ANTHROPIC_API_KEY=
