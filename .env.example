# ── Banco de dados (Supabase) ─────────────────────────────────────────────────
# Cole aqui a connection string do Supabase:
# Project Settings → Database → Connection string → URI
# Troque [YOUR-PASSWORD] pela senha que você definiu ao criar o projeto
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── Segredos de autenticação ──────────────────────────────────────────────────
# Gere valores aleatórios e fortes em produção:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=MUDE_PARA_UM_VALOR_SECRETO_E_LONGO
ADMIN_SECRET=MUDE_PARA_OUTRO_VALOR_SECRETO_E_LONGO

# ── Painel administrativo ─────────────────────────────────────────────────────
ADMIN_USER=admin@seudominio.com
ADMIN_PASSWORD=senha-admin-segura

# ── Configurações do servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (adicione a URL do seu frontend em produção) ─────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
